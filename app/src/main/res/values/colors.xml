        text_primary  : main body text — must be dark on light backgrounds.
        Your previous value #d3d3e0 was near-white and invisible on bg_primary.
        Fixed to #1A1A2E (dark navy).
    -->
    <color name="text_primary">#1A1A2E</color>
    <color name="text_secondary">#6B7280</color>
    <color name="text_on_primary">#FFFFFF</color>
    <color name="text_hint">#9CA3AF</color>

    <!--
        text_dark : alias kept from your file — same value as text_primary.
        Used in older layout XML files that reference @color/text_dark.
    -->
    <color name="text_dark">#1A1A2E</color>

    <!--
        blue : your custom accent blue, kept as-is.
    -->
    <color name="blue">#0740FA</color>

    <!-- ── Surfaces ───────────────────────────────────────────────── -->
    <color name="bg_primary">#F4F6FA</color>
