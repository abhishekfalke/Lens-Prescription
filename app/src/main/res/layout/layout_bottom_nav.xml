<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Top divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="16dp">

        <!-- Home tab -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_home"
                android:contentDescription="Home"
                app:tint="@color/text_secondary"/>

            <TextView
                android:id="@+id/navHomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="@color/divider"/>

        <!-- Add tab -->
        <LinearLayout
            android:id="@+id/navAdd"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navAddIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_add"
                android:contentDescription="Add"
                app:tint="@color/text_secondary"/>

            <TextView
                android:id="@+id/navAddLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_add"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="@color/divider"/>

        <!-- Records tab -->
        <LinearLayout
            android:id="@+id/navRecords"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navRecordsIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_records"
                android:contentDescription="Records"
                app:tint="@color/text_secondary"/>

            <TextView
                android:id="@+id/navRecordsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_records"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="@color/divider"/>

        <!-- Insights tab -->
        <LinearLayout
            android:id="@+id/navInsights"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:paddingTop="10dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/navInsightsIcon"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_insights"
                android:contentDescription="Insights"
                app:tint="@color/text_secondary"/>

            <TextView
                android:id="@+id/navInsightsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nav_insights"
                android:textSize="11sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>